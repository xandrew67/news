# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional - X/Twitter posting (leave blank to only write to output file)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Scheduling (cron-style, default: every 2 hours)
POLL_INTERVAL_MINUTES=120

# Minimum newsworthiness score to post (0-10)
MIN_NEWSWORTHY_SCORE=6

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
